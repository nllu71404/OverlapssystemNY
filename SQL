-- Audit Trail Triggers
-- Audit Trigger for Resident table
CREATE TRIGGER trg_Audit_Resident
ON dbo.Resident
AFTER INSERT, UPDATE, DELETE
AS
BEGIN
SET NOCOUNT ON;

-- INSERT
INSERT INTO dbo.AuditLog
(
    TableName,
    Operation,
    PrimaryKeyValue,
    BeforeData,
    AfterData,
    ChangedBy,
    ChangeDate
)
SELECT
    'Resident',
    'INSERT',
    CAST(i.ResidentId AS nvarchar(200)),
    NULL,
    (SELECT i.* FOR JSON PATH, WITHOUT_ARRAY_WRAPPER),
    SUSER_SNAME(),
    SYSDATETIME()
FROM inserted i
LEFT JOIN deleted d
    ON d.ResidentId = i.ResidentId
WHERE d.ResidentId IS NULL;

-- DELETE
INSERT INTO dbo.AuditLog
(
    TableName,
    Operation,
    PrimaryKeyValue,
    BeforeData,
    AfterData,
    ChangedBy,
    ChangeDate
