-- Get Residents by department ID
CREATE OR ALTER   PROCEDURE [dbo].[uspGetResidentsByDepartmentID]
@DepartmentID INT
AS
BEGIN
SET NOCOUNT ON;

    SELECT 
        r.ResidentID,
        r.ResidentName,
        r.ResidentStatus,
        r.DepartmentID,
        r.Risk,
        r.Mood,
        r.Activity,
        r.FamilyNote,
        r.ResidentEmployee,

        -- Medicin
        m.MedicinTimeID,
        m.MedicinTime,
        m.IsChecked,
        m.MedicinCheckTimeStamp,

        -- PN Medicin
        pn.PNID,
        pn.PNTime,
        pn.PNTimeStamp,
        pn.Reason,

        -- Shopping
        s.ShoppingID,
        s.ShoppingDay,
        s.ShoppingTime,
        s.PaymentMethod

    FROM Resident r

    LEFT JOIN MedicinTime m 
        ON r.ResidentID = m.ResidentID

    LEFT JOIN PNMedicin pn 
        ON r.ResidentID = pn.ResidentID

    LEFT JOIN Shopping s
    ON r.ResidentID = s.ResidentID

    WHERE r.DepartmentID = @DepartmentID
END;
GO

