-- Creates Stored Procedures
-- Creates a Resident to the table of Residents.
CREATE OR ALTER PROCEDURE dbo.uspCreateResident
@ResidentName NVARCHAR(100),
@DepartmentID INT = NULL,
@ResidentStatus NVARCHAR(100) = NULL,
@Risk NVARCHAR(100) = NULL
AS
BEGIN
SET NOCOUNT ON;

INSERT INTO dbo.Resident
(
    ResidentName,
    DepartmentID,
    ResidentStatus,
    Risk
)
VALUES
(
    @ResidentName,
    @DepartmentID,
    @ResidentStatus,
    @Risk
);

SELECT SCOPE_IDENTITY() AS ResidentID;
END;
GO

-- Gets all Residents from the resident table.
CREATE OR ALTER PROCEDURE dbo.uspGetResidents
AS
BEGIN
SET NOCOUNT ON;
SELECT * FROM dbo.Resident
END;
GO

-- Updates a resident by id in the resident table
CREATE OR ALTER PROCEDURE dbo.uspUpdateResidentById
@ResidentName NVARCHAR(100),
@DepartmentID INT = NULL,
@ResidentStatus NVARCHAR(100) = NULL,
@Risk NVARCHAR(100) = NULL,
@ResidentId INT
AS
BEGIN
    UPDATE dbo.Resident
    SET ResidentName = @ResidentName, 
    ResidentStatus = @ResidentStatus, 
    Risk = @Risk,
    DepartmentID = @DepartmentID
    WHERE ResidentID = @ResidentId;

END;
GO

-- Delete an entry in the resident table
CREATE OR ALTER PROCEDURE dbo.uspDeleteResident
@ResidentId INT
AS
BEGIN
DELETE FROM dbo.Resident WHERE ResidentID = @ResidentID
END;
GO

-- Get Residents by department ID
CREATE OR ALTER PROCEDURE dbo.uspGetResidentsByDepartmentID
@DepartmentID INT
AS
BEGIN
SELECT * FROM dbo.Resident WHERE DepartmentID = @DepartmentID
END;
GO

