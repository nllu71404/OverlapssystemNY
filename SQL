-- Creates Stored Procedures
-- Creates a Resident to the table of Residents.
CREATE OR ALTER PROCEDURE dbo.uspCreateResident
@ResidentName NVARCHAR(100),
@DepartmentID INT = NULL,
@ResidentStatus NVARCHAR(100) = NULL,
@Risk NVARCHAR(100) = NULL,
@Mood NVARCHAR(100) = NULL,
@Activity NVARCHAR(250) NULL,
@FamilyNote NVARCHAR(250) NULL,
@ResidentEmployee NVARCHAR(250) NULL
AS
BEGIN
SET NOCOUNT ON;

INSERT INTO dbo.Resident
(
    ResidentName,
    DepartmentID,
    ResidentStatus,
    Risk,
    Mood,
    Activity,
    FamilyNote,
    ResidentEmployee
)
VALUES
(
    @ResidentName,
    @DepartmentID,
    @ResidentStatus,
    @Risk,
    @Mood,
    @Activity,
    @FamilyNote,
    @ResidentEmployee
);

SELECT SCOPE_IDENTITY() AS ResidentID;
END;
GO

-- Gets all Residents from the resident table.
CREATE OR ALTER   PROCEDURE [dbo].[uspGetResidents]
AS
BEGIN
SET NOCOUNT ON;
SELECT 
    r.ResidentID,
    r.ResidentName,
    r.ResidentStatus,
    r.DepartmentID,
    r.Risk,
    r.Mood,
    r.Activity,
    r.FamilyNote,
    r.ResidentEmployee,

    m.MedicinTimeID,
    m.MedicinTime,
    m.IsChecked,
    m.MedicinCheckTimeStamp,

    pn.PNID,
        pn.PNTime,
        pn.PNTimeStamp,
        pn.Reason,

    -- Shopping
    s.ShoppingID,
    s.ShoppingDay,
    s.ShoppingTime,
    s.PaymentMethod

FROM Resident r
LEFT JOIN MedicinTime m ON r.ResidentID = m.ResidentID
LEFT JOIN PNMedicin pn 
        ON r.ResidentID = pn.ResidentID
LEFT JOIN Shopping s
    ON r.ResidentID = s.ResidentID
END;
GO

-- Updates a resident by id in the resident table
CREATE OR ALTER PROCEDURE dbo.uspUpdateResidentById
@ResidentName NVARCHAR(100),
@DepartmentID INT = NULL,
@ResidentStatus NVARCHAR(100) = NULL,
@Risk NVARCHAR(100) = NULL,
@Mood NVARCHAR(100) = NULL,
@ResidentId INT,
@Activity NVARCHAR(250) NULL,
@FamilyNote NVARCHAR(250) NULL,
@ResidentEmployee NVARCHAR(250) NULL
AS
BEGIN
    UPDATE dbo.Resident
    SET ResidentName = @ResidentName, 
    ResidentStatus = @ResidentStatus, 
    Risk = @Risk,
    Mood = @Mood,
    Activity = @Activity,
    FamilyNote = @FamilyNote,
    ResidentEmployee = @ResidentEmployee,
    DepartmentID = @DepartmentID
    WHERE ResidentID = @ResidentId;

END;
GO

