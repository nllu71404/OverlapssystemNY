-- Sets MedicinCheckTimeStamp and IsChecked
CREATE OR ALTER PROCEDURE [dbo].[uspSetMedicinChecked]
    @MedicinTimeID INT,
    @IsChecked BIT
AS
BEGIN
    UPDATE MedicinTime
    SET 
        IsChecked = @IsChecked,
        MedicinCheckTimeStamp = CASE 
            WHEN @IsChecked = 1 THEN GETDATE()
            ELSE NULL
        END
    WHERE MedicinTimeID = @MedicinTimeID;
END;
GO

