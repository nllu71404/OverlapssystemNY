		  <PrivateAssets>all</PrivateAssets>
		</PackageReference>
		<PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="8.0.0" />
		<PackageReference Include="Microsoft.VisualStudio.Azure.Containers.Tools.Targets" Version="1.22.1" />
		<PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\OverlapssytemApplication\OverlapssytemApplication.csproj" />
		<ProjectReference Include="..\OverlapssystemShared\OverlapssystemShared.csproj" />
		<ProjectReference Include="..\OverlapssystemInfrastructure\OverlapssystemInfrastructure.csproj" />
	</ItemGroup>

</Project>