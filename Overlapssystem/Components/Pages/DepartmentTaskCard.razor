@using OverlapssystemDomain.Entities
@using Overlapssystem.Services
@inject DepartmentTaskApiService departmentTaskApiService
@inject IJSRuntime JS

<div class="department-task-card">
    <div class="task-card-header">
        <select class="shift-select" @bind="selectedShift">
            <option value="">-- Vælg vagttype --</option>
            <option value="Dagvagt">Dagvagt</option>
            <option value="Aftenvagt">Aftenvagt</option>
            <option value="Nattevagt">Nattevagt</option>
        </select>
        @if (!IsReadOnly)
        {
            <button class="btn-plus" @onclick="() => OnAdd.InvokeAsync(DepartmentId)">+</button>
        }
    </div>
    <table class="task-table">
        <thead>
            <tr>
                <th>Særligt ansvarlige</th>
                <th>Navn</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in Tasks)
            {
                <tr>
                    <td>
                        @if (IsReadOnly)
                        {
                            <span>@task.DepartmentTaskTopic</span>
                        }
                        else
                        {
                            <input value="@task.DepartmentTaskTopic"
                                   @onchange="async e => {
                                   task.DepartmentTaskTopic = e.Value?.ToString();
                                   await UpdateDepartmentTask(task);
                               }" />
                    }
                </td>
                <td>
                    <input value="@task.EmployeeName"
                           @onchange="async e => {
                           task.EmployeeName = e.Value?.ToString();
                           await UpdateDepartmentTask(task);
                                                          }"
                           placeholder="Navn" />
                </td>
            </tr>
                        }
        </tbody>
    </table>
</div>

@code {
    
    private string selectedShift = "";
    [Parameter]
    public int DepartmentId { get; set; }
    [Parameter]
	public bool IsReadOnly { get; set; } = false;   

    // Parent will handle creation; we invoke it with the DepartmentId.
    [Parameter]
    public EventCallback<int> OnAdd { get; set; }

    [Parameter]
    public EventCallback<DepartmentTaskModel> OnDelete { get; set; }

    public List<DepartmentTaskModel> Tasks { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        Tasks = await departmentTaskApiService.GetDepartmentTasksByDepartmentId(DepartmentId);
    }

    // Allow parent to ask this component to refresh its list after parent creates/updates.
    public async Task RefreshAsync()
    {
        Tasks = await departmentTaskApiService.GetDepartmentTasksByDepartmentId(DepartmentId);
        StateHasChanged();
    }

    private async Task UpdateDepartmentTask(DepartmentTaskModel task)
    {
        await departmentTaskApiService.UpdateDepartmentTask(task.DepartmentTaskID, task);
    }
}