@using OverlapssystemDomain.Entities
@using Overlapssystem.Services
@using OverlapssystemDomain.Enums;
@using Overlapssystem.Facades;
@using Overlapssystem.ViewModels;
@using Overlapssystem.Interfaces;

@inject IDepartmentTaskFacade departmentTaskFacade
@inject IJSRuntime JS

<div class="department-task-card">
    <div class="task-card-header">
        <select class="shift-select" @bind="selectedShift">
            <option value="@ShiftType.Dag">Dagvagt</option>
            <option value="@ShiftType.Aften">Aftenvagt</option>
            <option value="@ShiftType.Nat">Nattevagt</option>
        </select>
        @if (!IsReadOnly)
        {
            <button class="btn-plus" @onclick="() => OnAdd.InvokeAsync(DepartmentId)">+</button>
        }
    </div>
    <table class="task-table">
        <thead>
            <tr>
                <th>Særligt ansvarlige</th>
                <th>Navn</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in Tasks.Where(t => t.ShiftType == selectedShift))
            {
                <tr>
                    <td>
                        @if (IsReadOnly)
                        {
                            <span>@task.DepartmentTaskTopic</span>
                        }
                        else
                        {
                            <input value="@task.DepartmentTaskTopic"
                                   @onchange="async e => {
                                   task.DepartmentTaskTopic = e.Value?.ToString();
                                   await UpdateDepartmentTask(task);
                               }" />
                    }
                </td>
                <td>
                    <input value="@task.EmployeeName"
                           @onchange="async e => {
                           task.EmployeeName = e.Value?.ToString();
                           await UpdateDepartmentTask(task);
                                                          }"
                           placeholder="Navn" />
                </td>
            </tr>
                        }
        </tbody>
    </table>
</div>

@code {
    private ShiftType selectedShift = ShiftType.Dag;
    [Parameter]
    public int DepartmentId { get; set; }
    [Parameter]
	public bool IsReadOnly { get; set; } = false;   

    // Parent will handle creation; we invoke it with the DepartmentId.
    [Parameter]
    public EventCallback<int> OnAdd { get; set; }

    [Parameter]
    public EventCallback<DepartmentTaskViewModel> OnDelete { get; set; }

    public List<DepartmentTaskViewModel> Tasks { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        Tasks = await departmentTaskFacade.GetDepartmentTasksByDepartment(DepartmentId);
    }

    // Allow parent to ask this component to refresh its list after parent creates/updates.
    public async Task RefreshAsync()
    {
        Tasks = await departmentTaskFacade.GetDepartmentTasksByDepartment(DepartmentId);
        StateHasChanged();
    }

    private async Task UpdateDepartmentTask(DepartmentTaskViewModel task)
    {
        await departmentTaskFacade.UpdateDepartmentTask(task);
    }
}