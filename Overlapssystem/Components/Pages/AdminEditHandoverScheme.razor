@page "/EditHandoverScheme/{departmentId:int}"
@rendermode InteractiveServer
@using OverlapssystemDomain.Entities
@using OverlapssystemDomain.Enums
@using OverlapssystemDomain.Interfaces
@using Overlapssystem.Services
@using Overlapssystem.Interfaces
@using Overlapssystem.ViewModels
@using OverlapssystemShared
@inject IJSRuntime JS

<h3>AdminEditHandoverScheme</h3>

@inject IResidentFacade residentFacade
@inject IDepartmentTaskFacade departmentTaskFacade
@inject IEmployeePhoneFacade employeePhoneFacade



<!-- Du opretter en ny beboer-->
<button @onclick="() => showCreateResident = !showCreateResident">
    Opret beboer
</button>

<h5>Oversigt over beboere</h5>
<!-- Du gemmer ændringer og sletter en beboer-->
@if (!residents.Any())
{
    <p> Ingen beboere fundet</p>
}
else

{
    <div class="resident-grid">
        @foreach (var resident in residents)
        {
            <ResidentCard Resident="resident"
                          OnSave="SaveResidentAsync"
                          OnDelete="DeleteResidentAsync" />
        }
        @if (showCreateResident)
        {
            <ResidentCard Resident="newResident"
                          OnSave="CreateResidentAsync"
                          OnDelete="DeleteResidentAsync" />
        }
    </div>
    
}

<DepartmentTaskCard @ref="departmentTaskCardRef"
                    DepartmentId="departmentId"
                    IsReadOnly="false"
                    OnAdd="AddDepartmentTask"
                    OnDelete="DeleteDepartmentTask" />

<EmployeePhoneCard @ref="employeePhoneCardRef"
                   DepartmentId="departmentId"
                   IsReadOnly="false"
                   OnAdd="AddEmployeePhoneNumber"
                   OnDelete="DeleteEmployeePhoneNumber" />



@code {
    private bool showCreateResident = false;
    [Parameter]
    public int departmentId { get; set; }

    private DepartmentTaskCard? departmentTaskCardRef;

    private EmployeePhoneCard? employeePhoneCardRef;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            residents = await residentFacade.GetResidentByDepartment(departmentId);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Fejl i åbning af afdeling");
            residents = new();
        }
    }


    private async Task LoadAllResidentsAsync()
    {
        residents = await residentFacade.GetAllResidents();
    }
    private async Task CreateResidentAsync()
    {
        var vm = new ResidentViewModel
        {
            DepartmentId = departmentId
        };
      
        var newID = await residentFacade.AddResident(vm);
        residents = await residentFacade.GetResidentByDepartment(departmentId);
        showCreateResident = false;
    }
    private async Task SaveResidentAsync(ResidentViewModel vm)
    {
        await residentFacade.UpdateResident(vm);
        residents = await residentFacade.GetResidentByDepartment(departmentId);
    }
    private async Task DeleteResidentAsync(ResidentViewModel resident)
    {
        await residentFacade.DeleteResident(resident.ResidentId);

        residents = await residentFacade.GetResidentByDepartment(departmentId);
    }

    // Parent creates the task and then asks the child to refresh.
    private async Task AddDepartmentTask(int deptId)
    {
        var vm = new DepartmentTaskViewModel
        {
            DepartmentID = deptId,
            DepartmentTaskTopic = string.Empty
        };

       await departmentTaskFacade.AddDepartmentTask(vm);
       
        // Ask the child component to refresh its list
        if (departmentTaskCardRef is not null)
        {
            await departmentTaskCardRef.RefreshAsync();
        }
    }

    private async Task DeleteDepartmentTask(DepartmentTaskViewModel vm)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "Vil du slette denne opgave?");
        if (!ok) return;
        await departmentTaskFacade.DeleteDepartmentTask(vm.DepartmentTaskID);

        if (departmentTaskCardRef is not null)
        {
            await departmentTaskCardRef.RefreshAsync();
        }
    }

    private async Task AddEmployeePhoneNumber(int deptId) //Denne skal rettes så den får en Facade i stedet for at kalde API direkte
    {
        var vm = new EmployeePhoneViewModel
        {
            DepartmentID = deptId,
            PhoneNumber = string.Empty,
            EmployeeName = string.Empty
        };
        await employeePhoneFacade.AddEmployeePhone(vm);
        // Ask the child component to refresh its list
        if (employeePhoneCardRef is not null)
        {
            await employeePhoneCardRef.RefreshAsync();
        }
    }

    private async Task DeleteEmployeePhoneNumber(EmployeePhoneViewModel vm) 
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "Vil du slette dette telefonnummer?");
        if (!ok) return;
        await employeePhoneFacade.DeleteEmployeePhone(vm.EmployeePhoneID);
        if (employeePhoneCardRef is not null)
        {
            await employeePhoneCardRef.RefreshAsync();
        }
    }


    List<ResidentViewModel> residents = new();
    ResidentViewModel newResident = new ResidentViewModel { Risiko = Risiko.Green };

}
