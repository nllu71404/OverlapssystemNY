@page "/EditHandoverScheme/{departmentId:int}"
@rendermode InteractiveServer
@using OverlapssystemDomain.Entities
@using OverlapssystemDomain.Enums
@using OverlapssystemDomain.Interfaces
@using Overlapssystem.Services
@using OverlapssystemShared
@inject IJSRuntime JS

<h3>AdminEditHandoverScheme</h3>

@inject ResidentApiService api
@inject DepartmentTaskApiService departmentTaskApi

<!-- Du opretter en ny beboer-->
<button @onclick="() => showCreateResident = !showCreateResident">
    Opret beboer
</button>

<h5>Oversigt over beboere</h5>
<!-- Du gemmer ændringer og sletter en beboer-->
@if (!residents.Any())
{
    <p> Ingen beboere fundet</p>
}
else

{
    <div class="resident-grid">
        @foreach (var resident in residents)
        {
            <ResidentCard Resident="resident"
                          OnSave="SaveResidentAsync"
                          OnDelete="DeleteResidentAsync" />
        }
        @if (showCreateResident)
        {
            <ResidentCard Resident="newResident"
                          OnSave="CreateResidentAsync"
                          OnDelete="DeleteResidentAsync" />
        }
    </div>
    
}

<DepartmentTaskCard @ref="departmentTaskCardRef"
                    DepartmentId="departmentId"
                    IsReadOnly="false"
                    OnAdd="AddDepartmentTask"
                    OnDelete="DeleteDepartmentTask" />




@code {
    private bool showCreateResident = false;
    [Parameter]
    public int departmentId { get; set; }

    private DepartmentTaskCard? departmentTaskCardRef;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            residents = await api.GetByDepartment(departmentId);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Fejl i åbning af afdeling");
            residents = new();
        }
    }


    private async Task LoadAllResidentsAsync()
    {
        residents = await api.GetAllResidents();
    }
    private async Task CreateResidentAsync(ResidentModel resident)
    {
        newResident.DepartmentId = departmentId;
        var newID = await api.CreateResident(resident);
        resident.ResidentId = newID;
        residents.Add(resident);
        newResident = new ResidentModel { Risiko = Risiko.Green };
        showCreateResident = false;
    }
    private async Task SaveResidentAsync(ResidentModel resident)
    {
        await api.UpdateResident(resident.ResidentId, resident);
        residents = await api.GetByDepartment(departmentId);
    }
    private async Task DeleteResidentAsync(ResidentModel resident)
    {
        await api.DeleteResident(resident.ResidentId);
        residents.Remove(resident);
    }

    // Parent creates the task and then asks the child to refresh.
    private async Task AddDepartmentTask(int deptId)
    {
        var newTask = new DepartmentTaskModel
        {
            DepartmentID = deptId,
            DepartmentTaskTopic = string.Empty,
            EmployeeName = string.Empty
        };

        await departmentTaskApi.CreateDepartmentTask(newTask);

        // Ask the child component to refresh its list
        if (departmentTaskCardRef is not null)
        {
            await departmentTaskCardRef.RefreshAsync();
        }
    }

    private async Task DeleteDepartmentTask(DepartmentTaskModel task)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "Vil du slette denne opgave?");
        if (!ok) return;
        await departmentTaskApi.DeleteDepartmentTask(task.DepartmentTaskID);

        if (departmentTaskCardRef is not null)
        {
            await departmentTaskCardRef.RefreshAsync();
        }
    }


    List<ResidentModel> residents = new();
    ResidentModel newResident = new ResidentModel { Risiko = Risiko.Green };

}
