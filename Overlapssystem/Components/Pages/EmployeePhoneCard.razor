@using OverlapssystemDomain.Entities
@using Overlapssystem.Services
@using Overlapssystem.ViewModels
@using Overlapssystem.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using OverlapssytemApplication.Common.Result
@using OverlapssytemApplication.Common.Errors
@using System.Text.RegularExpressions

@inherits AppComponentBase
@inject IEmployeePhoneFacade employeePhoneFacade
@inject IJSRuntime JS


<!--- Viser tekniske fejl --->
@if (CurrentError?.Type == ErrorType.Technical || CurrentError?.Type == ErrorType.NotFound)
{
    <div class="technical-error-msg">
        <ErrorDisplay Message="@CurrentError?.Message" />
    </div>
}


<div class="phone-card">

    <div class="phone-card-header">

        <AuthorizeView Roles="Administrator">
            <Authorized>
                <button class="btn-plus"
                        @onclick="() => OnAdd.InvokeAsync(DepartmentId)">
                    +
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Telefonnummer</th>
                <th>Navn</th>
                <th>Test</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var employeePhone in EmployeePhones)
            {
                <tr>
                    <td>
                        <AuthorizeView>
                            <Authorized>
                                
                                @if (context.User.IsInRole("Administrator"))
                                {
                                    <div class="field-group">
                                    <input class="form-control @(HasErrorForId(employeePhone.EmployeePhoneID, "PhoneNumber") ? "input-error" : "")" value="@employeePhone.PhoneNumber"
                                           @onchange="async e =>
                                      {
                                              employeePhone.PhoneNumber = e.Value?.ToString();


                                             await UpdateEmployeePhone(employeePhone);
                                       }"  />

                                        @if (HasErrorForId(employeePhone.EmployeePhoneID, "PhoneNumber"))
                                        {
                                            <div class="field-error-msg">
                                                @GetErrorForId(employeePhone.EmployeePhoneID, "PhoneNumber")
                                            </div>
                                        }
                                       </div>
                                }
                                else if (context.User.IsInRole("Medarbejder"))
                                {
                                    <span>@employeePhone.PhoneNumber</span>
                                }
                                else if (context.User.IsInRole("Simpel"))
                                {
                                    <input value="@employeePhone.PhoneNumber" disabled />
                                }
                            </Authorized>
                        </AuthorizeView>
                    </td>

                    <td>
                        <AuthorizeView>
                            <Authorized>
                                @if (context.User.IsInRole("Medarbejder") || context.User.IsInRole("Administrator"))
                                {
                                    <input value="@employeePhone.EmployeeName"
                                           @onchange="async e =>
                                    {
                                         employeePhone.EmployeeName = e.Value?.ToString();
                                        await UpdateEmployeePhone(employeePhone);
                                     }"
                                           placeholder="Navn" />
                                }
                                else if (context.User.IsInRole("Simpel"))
                                {
                                    <input value="@employeePhone.EmployeeName" disabled />
                                }
                            </Authorized>
                        </AuthorizeView>
                    </td>

                    <td>
                        <AuthorizeView>
                            <Authorized>
                                @if (context.User.IsInRole("Medarbejder") || context.User.IsInRole("Administrator"))
                                {
                                   
                                    <input type="checkbox"
                                           checked="@employeePhone.Test"
                                           @onchange="async e =>
                                      {
                                         employeePhone.Test = (bool)e.Value;
                                         await UpdateEmployeePhone(employeePhone);
                                       }" />

                                }
                                else if (context.User.IsInRole("Simpel"))
                                {
                                    <input value="@employeePhoneViewModel.Test" disabled" />
                                }
                            </Authorized>
                        </AuthorizeView>
                    </td>

                    <td>
                        <AuthorizeView Roles="Administrator">
                            <Authorized>
                                <button class="btn-grey"
                                        @onclick="() => ConfirmDeleteAsync(employeePhone)">
                                    Slet
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


@code {
    [Parameter]
    public EmployeePhoneViewModel employeePhoneViewModel { get; set; } = new();

    [Parameter]
    public int DepartmentId { get; set; }
    [Parameter]
    public bool IsReadOnly { get; set; } = false;

    [Parameter]
    public EventCallback<int> OnAdd { get; set; }
    [Parameter]
    public EventCallback<EmployeePhoneViewModel> OnDelete { get; set; }


    public List<EmployeePhoneViewModel> EmployeePhones { get; set; } = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            EmployeePhones = await ExecuteAsyncT(() => employeePhoneFacade.GetEmployeePhonesByDepartment(DepartmentId));
            StateHasChanged();
        }
    }

    public async Task RefreshAsync() 
    {
        EmployeePhones = await ExecuteAsyncT(() => employeePhoneFacade.GetEmployeePhonesByDepartment(DepartmentId));
        StateHasChanged();
    }

    public async Task UpdateEmployeePhone(EmployeePhoneViewModel phone) 
    {

        if (!ValidateEmployeePhone(phone))
        {
            StateHasChanged();
            return;
        }

        await ExecuteAsync(async () => 
        {
            var result = await employeePhoneFacade.UpdateEmployeePhone(phone);

            if (!result.Success)
                return result.Error!;

            _fieldErrors.Remove(GetKey(phone.EmployeePhoneID, "PhoneNumber"));

            StateHasChanged();

            return Result.Ok();
        });

    }

    private async Task ConfirmDeleteAsync(EmployeePhoneViewModel employeePhone)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "Er du sikker på, at du vil slette dette telefonnummer?");

        if (!ok) return;

        await OnDelete.InvokeAsync(employeePhone);
    }

    // Validering af EmployeePhone data
    private bool ValidateEmployeePhone(EmployeePhoneViewModel employeePhone)
    {
        _fieldErrors.Remove(GetKey(employeePhone.EmployeePhoneID, "PhoneNumber"));
        _fieldErrors.Remove(GetKey(employeePhone.EmployeePhoneID, "Name"));

        employeePhone.PhoneNumber =
            employeePhone.PhoneNumber?.Trim();

        employeePhone.EmployeeName =
            employeePhone.EmployeeName?.Trim();

      
        if (!string.IsNullOrWhiteSpace(employeePhone.PhoneNumber))
        {
            // Maks længde
            if (employeePhone.PhoneNumber.Length > 20)
            {
                _fieldErrors[GetKey(employeePhone.EmployeePhoneID, "PhoneNumber")] =
                    "Telefonnummer er for langt";
            }

            // Gyldige tegn
            var regex = new Regex(@"^[\d\s\+\-\(\)]+$");

            if (!regex.IsMatch(employeePhone.PhoneNumber))
            {
                _fieldErrors[GetKey(employeePhone.EmployeePhoneID, "PhoneNumber")] =
                    "Telefonnummer indeholder ugyldige tegn";
            }

            // Minimum antal cifre
            var digitsOnly = new string(
                employeePhone.PhoneNumber
                    .Where(char.IsDigit)
                    .ToArray());

            if (digitsOnly.Length < 8)
            {
                _fieldErrors[GetKey(employeePhone.EmployeePhoneID, "PhoneNumber")] =
                    "Telefonnummer er for kort";
            }

            // Dublet-check
            bool exists = EmployeePhones.Any(x =>
                x.EmployeePhoneID != employeePhone.EmployeePhoneID &&
                x.PhoneNumber == employeePhone.PhoneNumber);

            if (exists)
            {
                _fieldErrors[GetKey(employeePhone.EmployeePhoneID, "PhoneNumber")] =
                    "Telefonnummer findes allerede";
            }
        }

        // Navn valgfrit
        if (!string.IsNullOrWhiteSpace(employeePhone.EmployeeName) &&
            employeePhone.EmployeeName.Length > 100)
        {
            _fieldErrors[GetKey(employeePhone.EmployeePhoneID, "Name")] = "Navn er for langt";
        }

        return _fieldErrors.Count == 0;
    }

}
