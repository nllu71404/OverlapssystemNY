@using OverlapssystemDomain.Entities
@using Overlapssystem.Services
@using Overlapssystem.ViewModels
@using Overlapssystem.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using OverlapssytemApplication.Common.Result
@using OverlapssytemApplication.Common.Errors

@inherits AppComponentBase
@inject IEmployeePhoneFacade employeePhoneFacade
@inject IJSRuntime JS


<!--- Viser tekniske fejl --->
@if (CurrentError?.Type == ErrorType.Technical || CurrentError?.Type == ErrorType.NotFound)
{
    <div class="technical-error-msg">
        <ErrorDisplay Message="@CurrentError?.Message" />
    </div>
}


<div class="phone-card">

    <!--- Viser valideringsfejl --->
    @if (CurrentError?.Type == ErrorType.Validation)
    {
        <div class="error-msg">
            <ErrorDisplay Message="@CurrentError?.Message" />
        </div>
    }

    <div class="phone-card-header">

        <AuthorizeView Roles="Administrator">
            <Authorized>
                <button class="btn-plus"
                        @onclick="() => OnAdd.InvokeAsync(DepartmentId)">
                    +
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Telefonnummer</th>
                <th>Navn</th>
                <th>Test</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var employeePhone in EmployeePhones)
            {
                <tr>
                    <td>
                        <AuthorizeView>
                            <Authorized>
                                @if (context.User.IsInRole("Administrator"))
                                {
                                    <input value="@employeePhone.PhoneNumber"
                                           @onchange="async e =>
                                      {
                                              employeePhone.PhoneNumber = e.Value?.ToString();
                                             await UpdateEmployeePhone(employeePhone);
                                       }" />
                                }
                                else if (context.User.IsInRole("Medarbejder"))
                                {
                                    <span>@employeePhone.PhoneNumber</span>
                                }
                                else if (context.User.IsInRole("Simpel"))
                                {
                                    <input value="@employeePhone.PhoneNumber" disabled />
                                }
                            </Authorized>
                        </AuthorizeView>
                    </td>

                    <td>
                        <AuthorizeView>
                            <Authorized>
                                @if (context.User.IsInRole("Medarbejder") || context.User.IsInRole("Administrator"))
                                {
                                    <input value="@employeePhone.EmployeeName"
                                           @onchange="async e =>
                                    {
                                         employeePhone.EmployeeName = e.Value?.ToString();
                                        await UpdateEmployeePhone(employeePhone);
                                     }"
                                           placeholder="Navn" />
                                }
                                else if (context.User.IsInRole("Simpel"))
                                {
                                    <input value="@employeePhone.EmployeeName" disabled />
                                }
                            </Authorized>
                        </AuthorizeView>
                    </td>

                    <td>
                        <AuthorizeView>
                            <Authorized>
                                @if (context.User.IsInRole("Medarbejder") || context.User.IsInRole("Administrator"))
                                {
                                   
                                    <input type="checkbox"
                                           checked="@employeePhone.Test"
                                           @onchange="async e =>
                                      {
                                         employeePhone.Test = (bool)e.Value;
                                         await UpdateEmployeePhone(employeePhone);
                                       }" />

                                }
                                else if (context.User.IsInRole("Simpel"))
                                {
                                    <input value="@employeePhoneViewModel.Test" disabled" />
                                }
                            </Authorized>
                        </AuthorizeView>
                    </td>

                    <td>
                        <AuthorizeView Roles="Administrator">
                            <Authorized>
                                <button class="btn-grey"
                                        @onclick="() => OnDelete.InvokeAsync(employeePhone)">
                                    Slet
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


@code {
    [Parameter]
    public EmployeePhoneViewModel employeePhoneViewModel { get; set; } = new();

    [Parameter]
	public int DepartmentId { get; set; }
	[Parameter]
	public bool IsReadOnly { get; set; } = false;

	[Parameter]
	public EventCallback<int> OnAdd { get; set; }
	[Parameter]
	public EventCallback<EmployeePhoneViewModel> OnDelete { get; set; }

	
	public List<EmployeePhoneViewModel> EmployeePhones { get; set; } = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            EmployeePhones = await ExecuteAsyncT(() => employeePhoneFacade.GetEmployeePhonesByDepartment(DepartmentId));
            StateHasChanged();
        }
    }

    public async Task RefreshAsync() 
    {
        EmployeePhones = await ExecuteAsyncT(() => employeePhoneFacade.GetEmployeePhonesByDepartment(DepartmentId));
        StateHasChanged();
	}

    public async Task UpdateEmployeePhone(EmployeePhoneViewModel phone) 
    {
        await ExecuteAsync(() => employeePhoneFacade.UpdateEmployeePhone(phone));
      
	}




}
