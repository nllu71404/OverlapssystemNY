@page "/HandoverScheme/{departmentId:int}"
@rendermode InteractiveServer
@using OverlapssystemDomain.Entities
@using OverlapssystemDomain.Enums
@using OverlapssystemDomain.Interfaces
@using Overlapssystem.Services
@using OverlapssystemShared
@using Overlapssystem.ViewModels
@using Overlapssystem.Interfaces
@using Overlapssystem.TokenService
@using Microsoft.AspNetCore.Components.Authorization
@using OverlapssytemApplication.Common.Result
@using OverlapssytemApplication.Common.Errors

@inherits AppComponentBase
@inject IResidentFacade residentFacade
@inject IDepartmentTaskFacade departmentTaskFacade
@inject IEmployeePhoneFacade employeePhoneFacade
@inject NavigationManager Navigation
@inject AuthState authState

<!--- Viser tekniske fejl --->
@if (CurrentError?.Type == ErrorType.Technical || CurrentError?.Type == ErrorType.NotFound)
{
    <div class="technical-error-msg">
        <ErrorDisplay Message="@CurrentError?.Message" />
    </div>
}

<!--- Viser valideringsfejl --->
@if (CurrentError?.Type == ErrorType.Validation)
{
    <div class="error-msg">
        <ErrorDisplay Message="@CurrentError?.Message" />
    </div>
}

@if (departmentId == 1)
{
    <h2 class="h2-style">Slottet</h2>
}
else if (departmentId == 2)
{
   <h2 class="h2-style">Skoven</h2>
}
else 
{
    <h2 class="h2-style">Ukendt afdeling</h2>
}


<AuthorizeView>
    <Authorized>
        <p class="standard-text">Logget ind som: @context.User.Identity?.Name</p>
        <p class="standard-text">Rolle: @string.Join(", ", context.User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value))</p>

    </Authorized>
    <NotAuthorized>
        <p class="standard-text">Ikke logget ind</p>
    </NotAuthorized>
</AuthorizeView>

<AuthorizeView Roles="Administrator">
    <Authorized>
        <div class="admin-action-bar">
            <button class="btn-grey" @onclick="ShowCreateResident">
                Opret beboer
            </button>
            <button class="btn-navigate-2" @onclick="GoToCreateUser">
                Opret bruger
            </button>
            <button class="btn-navigate-1" @onclick="GoToAuditTrail">
                Audit log
                </button>
        </div>
    </Authorized>
</AuthorizeView>

@if (residents == null || !residents.Any())
{
    <p>Ingen beboere fundet</p>
    
}
else
{
    <div class="resident-grid">
        @foreach (var resident in residents)
        {
            <ResidentCard Resident="resident"
                          OnSave="SaveResidentAsync"
                          OnDelete="DeleteResidentAsync" />
        }
        @if (showCreateResident)
        {
            <ResidentCard Resident="newResident"
                          OnSave="SaveResidentAsync"
                          OnDelete="DeleteResidentAsync" />
        }
    </div>

}

<div class="card-container">
            <DepartmentTaskCard @ref="departmentTaskCard"
                DepartmentId="departmentId"
                OnAdd="AddDepartmentTaskAsync"
                OnDelete="DeleteDepartmentTaskAsync"/>

            <EmployeePhoneCard @ref="employeePhoneCard"
                DepartmentId="departmentId"
                OnAdd="AddEmployeePhoneAsync"
                OnDelete="DeleteEmployeePhoneAsync"/>
</div>

<!-- Log ind knap nederst -->
<div class="login-bar">
    <button class="login-logout-btn" @onclick="LogIn">Log ind</button>
    <button class="login-logout-btn" @onclick="LogOut">Log ud </button>
</div>



@code {


    [Parameter]
    public int departmentId { get; set; }

    private bool showCreateResident = false;
    private DepartmentTaskCard? departmentTaskCard;
    private EmployeePhoneCard? employeePhoneCard;

    ResidentViewModel newResident = new ResidentViewModel { Risiko = Risiko.Green };

    protected override async Task OnInitializedAsync()
    {
        await RefreshResidentsAsync();
    }

    private void GoToCreateUser()
    {
        Navigation.NavigateTo($"/OpretBruger/{departmentId}");
    }

    private void GoToAuditTrail()
    {
        Navigation.NavigateTo($"/audittrail/{departmentId}");
    }

    private async Task ShowCreateResident()
    {
        newResident = new ResidentViewModel
        {
            Risiko = Risiko.Green,
            DepartmentId = departmentId,
            Name = "Ny beboer"
        };

        var newId = await ExecuteAsyncT(() =>
            residentFacade.AddResident(newResident));

        if (newId <= 0)
            return;

        newResident.ResidentId = newId;

        showCreateResident = true;
    }

    private async Task SaveResidentAsync(ResidentViewModel vm)
    {
        await ExecuteAsync(() => residentFacade.UpdateResident(vm));

        if (vm == newResident)
        {
            showCreateResident = false;
            await RefreshResidentsAsync();
            newResident = new ResidentViewModel { Risiko = Risiko.Green };
        }
        else
        {
            await RefreshResidentsAsync();
        }

        StateHasChanged();

    }

    private async Task DeleteResidentAsync(ResidentViewModel vm)
    {
        await ExecuteAsync(() => residentFacade.DeleteResident(vm.ResidentId));

        if (vm == newResident)
        {
            showCreateResident = false;
            newResident = new ResidentViewModel { Risiko = Risiko.Green };
        }

        await RefreshResidentsAsync();
        StateHasChanged();
    }

    //hjælpe metode til at opdatere beboer listen efter ændringer
    private async Task RefreshResidentsAsync()
    {
        residents = await ExecuteAsyncT(() =>
            residentFacade.GetResidentByDepartment(departmentId))
            ?? new();
    }

    //Tilføj og slet DepartmentTask
    private async Task AddDepartmentTaskAsync(int departmentId)
    {
        var newTask = new DepartmentTaskViewModel
        {
            DepartmentID = departmentId,
            DepartmentTaskTopic = "Ny opgave",
            EmployeeName = "",
            ShiftType = ShiftType.Dag
        };

        await ExecuteAsync(() => departmentTaskFacade.AddDepartmentTask(newTask));

        if (departmentTaskCard is not null) await departmentTaskCard.RefreshAsync();
    }

    private async Task DeleteDepartmentTaskAsync(DepartmentTaskViewModel vm)
    {
        await ExecuteAsync(() => departmentTaskFacade.DeleteDepartmentTask(vm.DepartmentTaskID));

        if (departmentTaskCard is not null)
            await departmentTaskCard.RefreshAsync();
    }

    private async Task AddEmployeePhoneAsync(int departmentId)
    {
        var empPhone = new EmployeePhoneViewModel
            {
                DepartmentID = departmentId,
                EmployeeName = "Ny medarbejder",
                PhoneNumber = "",
                Test = false
            };

        await ExecuteAsync(() => employeePhoneFacade.AddEmployeePhone(empPhone));

        if (employeePhoneCard is not null) await employeePhoneCard.RefreshAsync();
    }

    private async Task DeleteEmployeePhoneAsync(EmployeePhoneViewModel vm)
    {
        await ExecuteAsync(() => employeePhoneFacade.DeleteEmployeePhone(vm.EmployeePhoneID));

        if (employeePhoneCard is not null)
            await employeePhoneCard.RefreshAsync();
    }

    private async Task LogOut()
    {
        await authState.MarkUserAsLoggedOut();
        Navigation.NavigateTo("/", forceLoad: true);
    }
    private async Task LogIn()
    {
        await authState.MarkUserAsLoggedOut();
        Navigation.NavigateTo("/", forceLoad: true);
    }
    List<ResidentViewModel> residents = new();

    
}