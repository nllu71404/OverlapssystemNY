@page "/HandoverScheme/{departmentId:int}"
@rendermode InteractiveServer
@using OverlapssystemDomain.Entities
@using OverlapssystemDomain.Enums
@using OverlapssystemDomain.Interfaces
@using Overlapssystem.Services
@using OverlapssystemShared
@using Overlapssystem.ViewModels
@using Overlapssystem.Interfaces
@using Overlapssystem.TokenService
@using Microsoft.AspNetCore.Components.Authorization

@inject IResidentFacade residentFacade
@inject IDepartmentTaskFacade departmentTaskFacade
@inject IEmployeePhoneFacade employeePhoneFacade
@inject NavigationManager Navigation
@inject AuthState authState



<h3>Overlapsseddel</h3>
<h5>Beboere</h5>

<AuthorizeView>
    <Authorized>
        <p>Logget ind som: @context.User.Identity?.Name</p>
        <p>Rolle: @string.Join(", ", context.User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value))</p>

    </Authorized>
    <NotAuthorized>
        <p>Ikke logget ind</p>
    </NotAuthorized>
</AuthorizeView>

<AuthorizeView Roles="Administrator">
    <Authorized>
        <button @onclick="ShowCreateResident">
            Opret beboer
        </button>
    </Authorized>
</AuthorizeView>

@if (residents == null || !residents.Any())
{
    <p>Ingen beboere fundet</p>
    
}
else
{
    <div class="resident-grid">
        @foreach (var resident in residents)
        {
            <ResidentCard Resident="resident"
                          OnSave="SaveResidentAsync"
                          OnDelete="DeleteResidentAsync" />
        }
        @if (showCreateResident)
        {
            <ResidentCard Resident="newResident"
                          OnSave="SaveResidentAsync"
                          OnDelete="DeleteResidentAsync" />
        }
    </div>

}
            <DepartmentTaskCard @ref="departmentTaskCard"
                DepartmentId="departmentId"
                OnAdd="AddDepartmentTaskAsync"
                OnDelete="DeleteDepartmentTaskAsync"/>

            <EmployeePhoneCard @ref="employeePhoneCard"
                DepartmentId="departmentId"
                OnAdd="AddEmployeePhoneAsync"
                OnDelete="DeleteEmployeePhoneAsync"/>

<!-- Log ind knap nederst -->
<div class="login-bar">
    <button class="login-btn" @onclick="LogIn"> Log ind</button>
    <button class="logout-btn" @onclick="LogOut">Log ud</button>
</div>

@code {


    [Parameter]
    public int departmentId { get; set; }

    private bool showCreateResident = false;
    private bool isLoading = true;
    private DepartmentTaskCard? departmentTaskCard;
    private EmployeePhoneCard? employeePhoneCard;

    ResidentViewModel newResident = new ResidentViewModel { Risiko = Risiko.Green };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Console.WriteLine($"DepartmentId: {departmentId}");
            residents = await residentFacade.GetResidentByDepartment(departmentId);
            Console.WriteLine($"Residents count; {residents?.Count}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ShowCreateResident()
    {
        newResident = new ResidentViewModel
        {
            Risiko = Risiko.Green,
            DepartmentId = departmentId,
            Name = "Ny beboer" // Placeholder navn
        };
        var newID = await residentFacade.AddResident(newResident);
        newResident.ResidentId = newID;
        showCreateResident = true;
        StateHasChanged();
    }

    private async Task SaveResidentAsync(ResidentViewModel vm)
    {
        await residentFacade.UpdateResident(vm);

        if (vm == newResident)
        {
            showCreateResident = false;
            residents = await residentFacade.GetResidentByDepartment(departmentId);
            newResident = new ResidentViewModel { Risiko = Risiko.Green };
        }
        else
        {
            residents = await residentFacade.GetResidentByDepartment(departmentId);
        }

        StateHasChanged();
    }

    private async Task DeleteResidentAsync(ResidentViewModel vm)
    {
        await residentFacade.DeleteResident(vm.ResidentId);

        if (vm == newResident)
        {
            showCreateResident = false;
            newResident = new ResidentViewModel { Risiko = Risiko.Green };
        }

        residents = await residentFacade.GetResidentByDepartment(departmentId);
        StateHasChanged();
    }

    private async Task AddDepartmentTaskAsync(int departmentId)
    {
        var newTask = new DepartmentTaskViewModel
        {
            DepartmentID = departmentId,
            DepartmentTaskTopic = "Ny opgave",
            EmployeeName = "",
            ShiftType = ShiftType.Dag
        };

        await departmentTaskFacade.AddDepartmentTask(newTask);

        if (departmentTaskCard is not null) await departmentTaskCard.RefreshAsync();
    }

    private async Task DeleteDepartmentTaskAsync(DepartmentTaskViewModel vm)
    {
        await departmentTaskFacade.DeleteDepartmentTask(vm.DepartmentTaskID);

        if (departmentTaskCard is not null)
            await departmentTaskCard.RefreshAsync();
    }

    private async Task AddEmployeePhoneAsync(int departmentId)
    {
        var empPhone = new EmployeePhoneViewModel
            {
                DepartmentID = departmentId,
                EmployeeName = "Ny medarbejder",
                PhoneNumber = "",
                Test = false
            };

        await employeePhoneFacade.AddEmployeePhone(empPhone);

        if (employeePhoneCard is not null) await employeePhoneCard.RefreshAsync();
    }

    private async Task DeleteEmployeePhoneAsync(EmployeePhoneViewModel vm)
    {
        await employeePhoneFacade.DeleteEmployeePhone(vm.EmployeePhoneID);

        if (employeePhoneCard is not null)
            await employeePhoneCard.RefreshAsync();
    }

    private async Task LogOut()
    {
        await authState.MarkUserAsLoggedOut();
        Navigation.NavigateTo("/", forceLoad: true);
    }
    private async Task LogIn()
    {
        await authState.MarkUserAsLoggedOut();
        Navigation.NavigateTo("/", forceLoad: true);
    }
    List<ResidentViewModel> residents = new();

    
}