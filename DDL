-- Audit Trigger for AuditLogDetail
-- Audit Trigger for Resident table
CREATE OR ALTER TRIGGER dbo.trg_Audit_Resident_Details
ON dbo.Resident
AFTER INSERT, UPDATE, DELETE
AS
BEGIN
    SET NOCOUNT ON;

    ---------------------------------------------------
    -- INSERT: old values are NULL, new values exist --
    ---------------------------------------------------
    INSERT INTO dbo.AuditLogDetail
(
    TableName,
    PrimaryKeyValue,
    ColumnName,
    OldValue,
    NewValue,
    Operation,
    ChangedBy,
    ChangeDate,
    DepartmentID
)
SELECT
    'Resident',
    CAST(i.ResidentID AS nvarchar(200)),
    v.ColumnName,
    NULL,
    v.NewValue,
    'INSERT',
    SUSER_SNAME(),
    SYSDATETIME(),
    i.DepartmentID
FROM inserted i
LEFT JOIN deleted d 
    ON d.ResidentID = i.ResidentID
CROSS APPLY (VALUES
    ('ResidentName',     CAST(i.ResidentName AS nvarchar(max))),
    ('ResidentID',       CAST(i.ResidentID AS nvarchar(max))),
    ('DepartmentID',     CAST(i.DepartmentID AS nvarchar(max))),
    ('ResidentStatus',   CAST(i.ResidentStatus AS nvarchar(max))),
    ('Risk',             CAST(i.Risk AS nvarchar(max))),
    ('Mood',             CAST(i.Mood AS nvarchar(max))),
    ('Activity',         CAST(i.Activity AS nvarchar(max))),
    ('FamilyNote',       CAST(i.FamilyNote AS nvarchar(max))),
    ('ResidentEmployee', CAST(i.ResidentEmployee AS nvarchar(max)))
) v(ColumnName, NewValue)
WHERE d.ResidentID IS NULL;

    ----------------------------------------
    -- UPDATE: compare old and new values --
    ----------------------------------------
    INSERT INTO dbo.AuditLogDetail
    (
        TableName,
        PrimaryKeyValue,
        ColumnName,
        OldValue,
        NewValue,
        Operation,
        ChangedBy,
        ChangeDate,
        DepartmentID
    )
    SELECT
        'Resident',
        CAST(i.ResidentID AS nvarchar(200)),
        v.ColumnName,
        v.OldValue,
        v.NewValue,
        'UPDATE',
        SUSER_SNAME(),
        SYSDATETIME(),
        i.DepartmentID
    FROM inserted i
    INNER JOIN deleted d 
        ON d.ResidentID = i.ResidentID
    CROSS APPLY (VALUES
        ('ResidentName',     CAST(d.ResidentName AS nvarchar(max)),     CAST(i.ResidentName AS nvarchar(max))),
        ('ResidentID',       CAST(d.ResidentID AS nvarchar(max)),       CAST(i.ResidentID AS nvarchar(max))),
        ('DepartmentID',     CAST(d.DepartmentID AS nvarchar(max)),     CAST(i.DepartmentID AS nvarchar(max))),
        ('ResidentStatus',   CAST(d.ResidentStatus AS nvarchar(max)),   CAST(i.ResidentStatus AS nvarchar(max))),
        ('Risk',             CAST(d.Risk AS nvarchar(max)),             CAST(i.Risk AS nvarchar(max))),
        ('Mood',             CAST(d.Mood AS nvarchar(max)),             CAST(i.Mood AS nvarchar(max))),
        ('Activity',         CAST(d.Activity AS nvarchar(max)),         CAST(i.Activity AS nvarchar(max))),
        ('FamilyNote',       CAST(d.FamilyNote AS nvarchar(max)),       CAST(i.FamilyNote AS nvarchar(max))),
        ('ResidentEmployee', CAST(d.ResidentEmployee AS nvarchar(max)), CAST(i.ResidentEmployee AS nvarchar(max)))
    ) v(ColumnName, OldValue, NewValue)
    WHERE
        ISNULL(v.OldValue, N'<<NULL>>') <> ISNULL(v.NewValue, N'<<NULL>>');

   
    ----------------------------------------
    -- DELETE: compare old and new values --
    ----------------------------------------

   SELECT
    'Resident',
    CAST(d.ResidentID AS nvarchar(200)),
    v.ColumnName,
    v.OldValue,
    NULL,
    'DELETE',
    SUSER_SNAME(),
    SYSDATETIME(),
    d.DepartmentID
FROM deleted d
LEFT JOIN inserted i 
    ON i.ResidentID = d.ResidentID
CROSS APPLY (VALUES
    ('ResidentName',     CAST(d.ResidentName AS nvarchar(max))),
    ('ResidentID',       CAST(d.ResidentID AS nvarchar(max))),
    ('DepartmentID',     CAST(d.DepartmentID AS nvarchar(max))),
    ('ResidentStatus',   CAST(d.ResidentStatus AS nvarchar(max))),
    ('Risk',             CAST(d.Risk AS nvarchar(max))),
    ('Mood',             CAST(d.Mood AS nvarchar(max))),
    ('Activity',         CAST(d.Activity AS nvarchar(max))),
    ('FamilyNote',       CAST(d.FamilyNote AS nvarchar(max))),
    ('ResidentEmployee', CAST(d.ResidentEmployee AS nvarchar(max)))
) v(ColumnName, OldValue)
WHERE i.ResidentID IS NULL;
END;
GO


