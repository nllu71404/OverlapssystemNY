-- Sets MedicinCheckTimeStamp and IsChecked
CREATE OR ALTER PROCEDURE [dbo].[uspSetMedicinChecked]
    @MedicinTimeID INT,
    @IsChecked BIT
AS
BEGIN
    UPDATE MedicinTime
    SET 
        IsChecked = @IsChecked,
        MedicinCheckTimeStamp = CASE 
