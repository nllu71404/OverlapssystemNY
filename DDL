-- Creates Stored Procedure
-- Creates a AuditLogDetail to the table of AuditLogDetails.
CREATE OR ALTER PROCEDURE dbo.uspGetAuditTrailDetailsByDepartmentId
    @DepartmentId INT
AS
BEGIN
    SET NOCOUNT ON;

    SELECT
        DepartmentID,
        AuditLogDetailId,
        TableName,
        PrimaryKeyValue,
        ColumnName,
        OldValue,
        NewValue,
        Operation,
        ChangedBy,
        ChangeDate
    FROM dbo.AuditLogDetail
    WHERE DepartmentID = @DepartmentId
    ORDER BY ChangeDate DESC;
END;
